modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Attached-Assets && PORT=3001 DATABASE_URL=$DATABASE_URL pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Attached-Assets && PORT=5000 BASE_PATH=/ API_PORT=3001 pnpm --filter @workspace/quran-app run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd Attached-Assets && PORT=3001 DATABASE_URL=$DATABASE_URL node artifacts/api-server/dist/index.mjs & PORT=5000 BASE_PATH=/ node_modules/.bin/vite preview --config artifacts/quran-app/vite.config.ts --host 0.0.0.0"]
build = ["bash", "-c", "cd Attached-Assets && npm install -g pnpm@9 && pnpm install && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/quran-app run build"]
